PORT=3000
NODE_ENV=development

# Session Secret (CHANGE THIS!)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=savannah-spice-secret-key-2026

# Manager Portal Key (keep this secret)
MANAGER_PORTAL_KEY=change-this-manager-key

# Optional Sheet sync endpoint for live menu updates
MENU_SHEET_SYNC_URL=
MENU_SHEET_API_KEY=

# Optional Sheet API base URL for reservations/settings/menu tabs
SHEET_API_BASE_URL=
SHEET_API_KEY=

# Session Timeout (2 hours in milliseconds)
SESSION_TIMEOUT=7200000
