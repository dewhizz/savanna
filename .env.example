PORT=3000
NODE_ENV=development

# Session Secret (CHANGE THIS!)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=savannah-spice-secret-key-2024

# Default Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=savannah2024!

# Admin Route (customize to hide it)
ADMIN_ROUTE=http://localhost:3000/admin-login.html

# Session Timeout (2 hours in milliseconds)
SESSION_TIMEOUT=7200000

# Database Path
DB_PATH=./server/restaurant.db
